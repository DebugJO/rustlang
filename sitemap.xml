---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for post in site.posts %}
  <url>
    <loc>{{ site.url | append: post.url }}</loc>
    <lastmod>{{ post.lastmod | default: post.date | date_to_xmlschema }}</lastmod>
    <changefreq>{{ post.sitemap.changefreq | default: "daily" }}</changefreq>
    <priority>{{ post.sitemap.priority | default: "0.5" }}</priority>
  </url>
  {% endfor %}
  {% for page in site.pages %}
  {% if page.url contains ".html" or page.url contains "/" %}
  <url>
    <loc>{{ site.url | append: page.url }}</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.3</priority>
  </url>
  {% endif %}
  {% endfor %}
</urlset>
